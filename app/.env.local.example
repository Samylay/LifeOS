# LifeOS — self-hosted config. Copy to .env.local for local dev.
# Data is stored in a local SQLite file. The AI features (chat / parse / brief)
# run through the Claude Code CLI (`claude -p`) by default — see GEN_PROVIDER
# below — with a local Ollama instance as the fallback backend.

# --- Local database ---------------------------------------------------------
# Path to the SQLite file. Defaults to ./data/lifeos.db when unset.
# In Docker this is set to /data/lifeos.db (a mounted volume).
LIFEOS_DB_PATH=./data/lifeos.db

# --- Local LLM (Ollama) — FALLBACK ONLY -------------------------------------
# Only used when GEN_PROVIDER is not "claude-cli". Base URL of the Ollama
# server; for local dev this is the loopback address, inside Docker it's
# http://host.docker.internal:11434 (see docker-compose.yml).
OLLAMA_BASE_URL=http://127.0.0.1:11434
# A tool-capable model (`ollama pull qwen2.5:7b`); only the Ollama chat path
# uses native tool-calling. The default claude-cli path does not need this.
OLLAMA_MODEL=qwen2.5:7b

# --- Knowledge base (Hermes-managed Obsidian vault) -------------------------
# Absolute path to the vault. When set, the /knowledge page can browse, search,
# and capture notes. In Docker this is /vault (a mounted volume); leave unset
# for local dev to disable the feature gracefully.
KB_PATH=
# Notes created by LifeOS are chowned to this uid/gid so Hermes (the host user
# that owns the vault) can append its ## Hermes summary/tags. Defaults to 1000.
KB_UID=1000
KB_GID=1000

# --- Flux (content engine, sibling app) -------------------------------------
# URL the sidebar "Content (Flux)" link points to. Baked into the client at
# build time.
NEXT_PUBLIC_FLUX_URL=http://homelab.tail069527.ts.net

# --- Finance (Enable Banking, T67–T72) --------------------------------------
# App ID (a UUID) from the Enable Banking Control Panel — set by Samy when T67
# lands; empty until then, and src/lib/enable-banking.ts (T68) must degrade
# cleanly via an isConfigured() guard while it is. The matching private key is
# a FILE (~/.config/homelab/enable-banking.pem), NOT an env string — see
# docker-compose.yml and .scratch/finance-tracker/MAP.md Q5 for how it reaches
# the container. Never commit or log either credential.
ENABLE_BANKING_APP_ID=

# --- AI backend (Claude Code CLI) -------------------------------------------
# "claude-cli" (default) runs chat / parse / brief / goal-drafting via
# `claude -p` using your Claude subscription (no API key). Set to "ollama" to
# fall back to the local model. Requires the CLI installed.
GEN_PROVIDER=claude-cli
CLAUDE_CLI_MODEL=sonnet
# Auth for `claude -p`: a long-lived token from `claude setup-token`. A
# standalone CLI can't use a mounted ~/.claude (it reports "Not logged in"),
# so set this token — the Docker container reads it via env_file.
CLAUDE_CODE_OAUTH_TOKEN=
# Where Claude config/auth lives inside the container.
CLAUDE_CONFIG_DIR=/root/.claude
