# LifeOS — self-hosted config. Copy to .env.local for local dev.
# There are no cloud accounts or API keys: data is stored in a local SQLite
# file and the AI features run against a local Ollama instance.

# --- Local database ---------------------------------------------------------
# Path to the SQLite file. Defaults to ./data/lifeos.db when unset.
# In Docker this is set to /data/lifeos.db (a mounted volume).
LIFEOS_DB_PATH=./data/lifeos.db

# --- Local LLM (Ollama) -----------------------------------------------------
# Base URL of the Ollama server. For local dev this is the loopback address;
# inside Docker it's http://host.docker.internal:11434 (see docker-compose.yml).
OLLAMA_BASE_URL=http://127.0.0.1:11434
# Any model you've pulled with `ollama pull`. qwen2.5 supports tool-calling,
# which the assistant/chat feature relies on.
OLLAMA_MODEL=qwen2.5:7b

# --- Knowledge base (Hermes-managed Obsidian vault) -------------------------
# Absolute path to the vault. When set, the /knowledge page can browse, search,
# and capture notes. In Docker this is /vault (a mounted volume); leave unset
# for local dev to disable the feature gracefully.
KB_PATH=
# Notes created by LifeOS are chowned to this uid/gid so Hermes (the host user
# that owns the vault) can append its ## Hermes summary/tags. Defaults to 1000.
KB_UID=1000
KB_GID=1000

# --- Flux (content engine, sibling app) -------------------------------------
# URL the sidebar "Content (Flux)" link points to. Baked into the client at
# build time.
NEXT_PUBLIC_FLUX_URL=http://homelab.tail069527.ts.net

# --- AI goal drafting (Claude Code CLI) -------------------------------------
# "claude-cli" drafts quarterly goal plans via `claude -p` using your logged-in
# Claude subscription (no API key). Requires the CLI installed and ~/.claude
# mounted (see docker-compose.yml). Anything else falls back to Ollama.
GEN_PROVIDER=claude-cli
CLAUDE_CLI_MODEL=sonnet
# Where the mounted Claude auth lives inside the container.
CLAUDE_CONFIG_DIR=/root/.claude
